# =============================================================================
# 專案名稱: ai-tools-compose
# 檔案用途: Docker Compose 環境變數範本檔 (.env.example)
# 說明: 請複製本檔案並另存為 `.env`，再根據實際部署需求修改變數內容。
# =============================================================================

# =============================================================================
# 1. Ollama 大語言模型服務設定
# =============================================================================
# OLLAMA_DOCKER_TAG: 指定 Ollama 容器映像檔標籤 (預設 latest)
OLLAMA_DOCKER_TAG=latest

# OLLAMA_BASE_URL: Open WebUI 連接 Ollama 容器之內部網路位址
#OLLAMA_BASE_URL='http://localhost:11434'
OLLAMA_BASE_URL='http://ollama:11434'

# =============================================================================
# 2. Open WebUI 圖形介面設定
# =============================================================================
# WEBUI_DOCKER_TAG: 指定 Open WebUI 容器映像檔標籤 (預設 main)
WEBUI_DOCKER_TAG=main

# WEBUI_SECRET_KEY: WebUI 後端用於加密 Session 與 Cookie 的金鑰 (請更換為隨機密碼)
WEBUI_SECRET_KEY='your_random_secret_key_here'

# ENABLE_SIGNUP: 是否開放新使用者註冊 (False 表示僅允許管理者預建立帳號)
ENABLE_SIGNUP=False

# ENABLE_PERSISTENT_CONFIG: 是否開啟持久化設定 (False 表示優先讀取本 .env 檔設定)
#ENABLE_PERSISTENT_CONFIG=True
ENABLE_PERSISTENT_CONFIG=False 

OPENAI_API_BASE_URL=''
OPENAI_API_KEY=''

# AUTOMATIC1111_BASE_URL="http://localhost:7860"

# For production, you should only need one host as
# fastapi serves the svelte-kit built frontend and backend from the same host and port.
# To test with CORS locally, you can set something like
# CORS_ALLOW_ORIGIN='http://localhost:5173;http://localhost:8080'
CORS_ALLOW_ORIGIN='*'

# For production you should set this to match the proxy configuration (127.0.0.1)
FORWARDED_ALLOW_IPS='*'

# DO NOT TRACK
SCARF_NO_ANALYTICS=true
DO_NOT_TRACK=true
ANONYMIZED_TELEMETRY=false

# =============================================================================
# 3. Qdrant 向量資料庫設定 (RAG 檢索增強)
# =============================================================================
# VECTOR_DB: 指定向量資料庫類型 (qdrant)
VECTOR_DB=qdrant

# QDRANT_URI: Qdrant 服務內部連線位址與 REST API 埠號
QDRANT_URI=http://qdrant:6333

# QDRANT_API_KEY: Qdrant 管理員寫入與查詢 API 存取金鑰 (請更換為自訂密碼)
QDRANT_API_KEY='your_qdrant_api_key_here'

# QDRANT_SERVICE_READ_ONLY_API_KEY: Qdrant 唯讀 API 存取金鑰 (請更換為自訂密碼)
QDRANT_SERVICE_READ_ONLY_API_KEY='your_qdrant_readonly_api_key_here'

# =============================================================================
# 4. Apache Tika 文件解析伺服器設定
# =============================================================================
# TIKA_SERVER_URL: Open WebUI 調用 Tika 萃取 PDF/DOCX 內文之內部服務位址
TAG=3.3.0.0
TIKA_SERVER_URL=http://tika:9998

# =============================================================================
# 5. PostgreSQL 16 資料庫設定 (n8n 後端存儲)
# =============================================================================
# POSTGRES_USER: PostgreSQL 最高權限管理者帳號
POSTGRES_USER=root

# POSTGRES_PASSWORD: PostgreSQL 最高權限管理者密碼
POSTGRES_PASSWORD=your_postgres_root_password

# POSTGRES_DB: PostgreSQL 預設建立之資料庫名稱
POSTGRES_DB=n8n

# POSTGRES_NON_ROOT_USER: 提供給 n8n 使用之專用一般使用者帳號
POSTGRES_NON_ROOT_USER=n8n_user

# POSTGRES_NON_ROOT_PASSWORD: n8n 專用一般使用者密碼
POSTGRES_NON_ROOT_PASSWORD=your_n8n_user_password

# =============================================================================
# 6. n8n 工作流自動化服務設定
# =============================================================================
### n8n configuration
# DOMAIN_NAME and SUBDOMAIN together determine where n8n will be reachable from
# The top level domain to serve from
DOMAIN_NAME=localhost

# N8N_DOMAIN_NAME: n8n 服務綁定主機網域名稱 (本機開發設為 localhost)
N8N_DOMAIN_NAME=localhost

# N8N_WEBHOOK_URL: n8n 接收對外 Webhook 回傳呼叫之完整 URL
N8N_WEBHOOK_URL=http://localhost:5678/

# The subdomain to serve from
SUBDOMAIN=n8n

# The above example serve n8n at: https://n8n.example.com

# Optional timezone to set which gets used by Cron and other scheduling nodes
# New York is the default value if not set
# GENERIC_TIMEZONE: n8n 排程節點與系統日誌所使用之標準時區
GENERIC_TIMEZONE=Asia/Taipei

# The email address to use for the TLS/SSL certificate creation
SSL_EMAIL=user@example.com

N8N_VERSION=stable
